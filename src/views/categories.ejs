<%- include("partials/header") %>

<main>
    <div class="layout-padding">
        <h1 class="header-margin-top header-font-size"><%= title %></h1>
        
        <p class="description-font-size gray-text">Explore the different areas where you can volunteer and make a meaningful impact in your community.</p>

        <div class="categories-container">
            <div class="category-card card card-details">
                <h2>Enviromental</h2>
                <p>Help protect and restore our natural environment through cleanups, conservation projects, and sustainability initiatives.</p>
            </div>
            <div class="category-card card card-details">
                <h2>Educational</h2>
                <p>Support learning and development by tutoring students, mentoring youth, and building educational resources.</p>
            </div>
            <div class="category-card card card-details">
                <h2>Community Service</h2>
                <p>Give back to your local community through food drives, housing projects, and outreach programs.</p>
            </div>
            <div class="category-card card card-details">
                <h2>Health & Wellness</h2>
                <p>Promote physical and mental well-being by supporting health clinics, wellness workshops, and care programs.</p>
            </div>
        </div>
    </div>
</main>

<%- include("partials/footer") %>